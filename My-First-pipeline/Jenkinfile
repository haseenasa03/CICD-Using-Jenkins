pipeline {
    agent {
        docker { image 'node:16-alpine' }
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Build') {
            steps {
                script {
                    sh 'node --version'
                    sh 'npm install'
                    // Add other build steps as needed
                }
            }
        }
    }
}

